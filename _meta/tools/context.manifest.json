{
  "repo": "synapse",
  "vaultRoot": ".",
  "skipDirs": ["node_modules", "dist", ".git", ".obsidian", "db"],
  "targetTypes": ["moc", "project", "plan"],
  "autoUpgrade": { "moc": "standard" },
  "dropTagsAtLean": ["status/draft"],
  "roles": {
    "CONSTRAINS": { "fields": ["applies_rules"], "direction": "forward" },
    "USES":       { "fields": ["invokes_skills", "uses_tools"], "direction": "forward" },
    "DELEGATES":  { "fields": ["delegates_to"], "direction": "forward" },
    "BINDS":      { "fields": ["related"], "direction": "reverse", "reverseName": "members",
                    "endpointTypes": ["note", "journal", "project", "plan", "contact", "account", "summary"] },
    "ATTACHES":   { "fields": ["related"], "direction": "both",
                    "endpointTypes": ["person", "decision", "tool", "glossary"] },
    "NAVIGATES":  { "fields": ["related"], "direction": "forward", "endpointTypes": ["moc"] },
    "REFERENCES": { "fields": ["references_docs"], "direction": "forward", "endpointTypes": ["doc"] }
  },
  "profiles": {
    "lean":     { "include": ["self", "CONSTRAINS", "USES", "DELEGATES"] },
    "standard": { "include": ["self", "target", "CONSTRAINS", "USES", "DELEGATES", "members", "ATTACHES", "NAVIGATES@1", "REFERENCES"] },
    "fat":      { "include": ["self", "target", "CONSTRAINS", "USES", "DELEGATES", "members", "ATTACHES", "REFERENCES"], "transitive": ["NAVIGATES", "members"] }
  },
  "tokenBudgets": { "lean": 4000, "standard": 15000, "fat": 30000 },
  "typePriority": ["agent", "loop", "moc", "rule", "tool", "skill", "recipe", "glossary", "doc", "decision", "person", "summary", "account", "contact", "project", "plan", "journal", "note"],
  "invariants": [
    { "when": { "targetType": "moc", "profile": "standard", "excludeIds": ["moc-synapse"] },
      "assert": ["members>=1", "tokens<=3*median"], "onFail": "report" }
  ]
}
